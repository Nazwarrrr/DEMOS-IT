# ============================================
# KALMAN FILTER UNTUK SMOOTH HAND TRACKING
# ============================================
class KalmanTracker:
    def __init__(self, process_variance, measurement_variance, initial_value=0):
        self.process_variance = process_variance
        self.measurement_variance = measurement_variance
        self.posteri_estimate = initial_value
        self.posteri_error_estimate = 1.0
        self.pri_estimate = initial_value
        self.pri_error_estimate = 1.0
    
    def update(self, measurement):
        # Prediction step
        self.pri_estimate = self.posteri_estimate
        self.pri_error_estimate = self.posteri_error_estimate + self.process_variance
        
        # Update step
        blending_factor = self.pri_error_estimate / (self.pri_error_estimate + self.measurement_variance)
        self.posteri_estimate = self.pri_estimate + blending_factor * (measurement - self.pri_estimate)
        self.posteri_error_estimate = (1 - blending_factor) * self.pri_error_estimate
        
        return self.posteri_estimate

