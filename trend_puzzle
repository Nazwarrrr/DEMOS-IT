# Particle System untuk efek visual
class Particle:
    def __init__(self, x, y, vx, vy, lifetime=30, color=(255, 255, 0)):
        self.x, self.y = x, y
        self.vx, self.vy = vx, vy
        self.lifetime = lifetime
        self.max_lifetime = lifetime
        self.color = color
    
    def update(self):
        self.x += self.vx
        self.y += self.vy
        self.vy += 0.3  # Gravity effect
        self.lifetime -= 1
    
    def draw(self, frame):
        alpha = self.lifetime / self.max_lifetime
        size = max(1, int(3 * alpha))
        cv2.circle(frame, (int(self.x), int(self.y)), size, self.color, -1)

particles = [] 

# Fungsi untuk membuat efek foto pixel art
def pixelate_image(img, pixel_size=10):
    h, w = img.shape[:2]
    # Perkecil gambar
    temp = cv2.resize(img, (w // pixel_size, h // pixel_size), interpolation=cv2.INTER_LINEAR)
    # Gedein lagi ke ukuran asli (efeknya jadi kotak-kotak piksel)
    return cv2.resize(temp, (w, h), interpolation=cv2.INTER_NEAREST)

# ============================================
# EFEK VISUAL ENHANCEMENT
# ============================================
def draw_neon_glow(frame, x, y, w, h, color=(0, 255, 255), intensity=10):
    """Draw neon glow effect around rectangle"""
    for i in range(intensity, 0, -1):
        alpha = int(255 * (1 - i / intensity) / 3)
        cv2.rectangle(frame, (x - i, y - i), (x + w + i, y + h + i), color, 1)

def add_text_shadow(frame, text, org, fontFace, fontScale, color, thickness, shadow_offset=3, shadow_color=(50, 50, 50)):
    """Add shadow effect ke text"""
    cv2.putText(frame, text, (org[0] + shadow_offset, org[1] + shadow_offset), 
                fontFace, fontScale, shadow_color, thickness + 1)
    cv2.putText(frame, text, org, fontFace, fontScale, color, thickness)

def draw_gradient_background(frame, color1=(10, 10, 30), color2=(20, 20, 50)):
    """Draw gradient background effect"""
    h, w = frame.shape[:2]
    for i in range(h):
        alpha = i / h
        color = tuple(int(color1[j] * (1 - alpha) + color2[j] * alpha) for j in range(3))
        cv2.line(frame, (0, i), (w, i), color, 1)

def create_grid_pattern(frame, grid_size=40, color=(30, 30, 30), thickness=1):
    """Create retro grid pattern"""
    h, w = frame.shape[:2]
    for i in range(0, w, grid_size):
        cv2.line(frame, (i, 0), (i, h), color, thickness)
    for j in range(0, h, grid_size):
        cv2.line(frame, (0, j), (w, j), color, thickness)

class PuzzlePiece:
    def __init__(self, img, correct_idx):
        self.img = img
        self.correct_idx = correct_idx  
        self.current_grid_idx = correct_idx 
        self.current_pos = [0.0, 0.0]
        self.kalman_x = KalmanTracker(0.01, 0.1, 0)
        self.kalman_y = KalmanTracker(0.01, 0.1, 0)

    def update_position_smooth(self, target_x, target_y):
        # Gunakan Kalman filter untuk smoothing
        smooth_x = self.kalman_x.update(target_x - piece_w // 2)
        smooth_y = self.kalman_y.update(target_y - piece_h // 2)
        self.current_pos[0] = smooth_x
        self.current_pos[1] = smooth_y

